    "version": "0.5.1",
    "description": "Manage multiple MoonBit installations",
    "homepage": "https://github.com/chawyehsu/moonup",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/chawyehsu/moonup/releases/download/v0.5.1/moonup-x86_64-pc-windows-msvc.zip",
            "hash": "15d927a94b8e07af404bc8e64ee6024bd927d3c37d6ff8c416caf8ae9c1712d7"
        }
    },
    "bin": "moonup.exe",
    "checkver": {
