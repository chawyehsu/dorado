{
    "homepage": "https://www.binance.com/",
    "description": "Binance's cryptocurrency exchange. Trade. Anywhere.",
    "version": "2.3.1",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://ftp.binance.com/electron-desktop/windows/production/binance-setup-2.3.1.exe#/binance-setup.7z",
            "hash": "sha512:720061f01e04c40005b3c98563b74b9faaa6c1db88589bf79af6c29825484f50361000d220bfaba676017dbcfa897abcf40668086c348cc416e0090ebe0c3dd8",
            "installer": {
                "script": [
                    "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                    "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninst*\" -Force -Recurse"
                ]
            }
        }
    },
    "shortcuts": [
        [
            "Binance.exe",
            "Binance"
        ]
    ],
    "checkver": {
        "url": "https://ftp.binance.com/electron-desktop/windows/production/latest.yml",
        "regex": "binance-setup-([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ftp.binance.com/electron-desktop/windows/production/binance-setup-$version.exe#/binance-setup.7z"
            }
        },
        "hash": {
            "url": "https://ftp.binance.com/electron-desktop/windows/production/latest.yml",
            "regex": "(?sm)$version.exe.*?sha512: $base64"
        }
    }
}
