        "32bit": {
            "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/150.0b8/win32/zh-CN/Firefox%20Setup%20150.0b8.exe#/firefox-developer.7z",
            "hash": "sha512:a014438e62432592dcb6cac81d2843997e3d54e7766fc8b4f52af504c8aaef46052c1273cfe3a04c34e802929fd1c60d00018a5b45ea56c5240527f982da5caf"
