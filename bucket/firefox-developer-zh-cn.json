            "hash": "sha512:06da981cda9af01500fb684ce9af5d47f7c4fbd22fd1d09738dfae9e8148ace03bc01e72f18896f852c5185c80ff4f1e79fc3be0c4b6a1ff10a3148dd3fcb54b"
