{
    "version": "2.145.0",
    "description": "Ledger Wallet, formerly Ledger Live (Desktop)",
    "homepage": "https://www.ledger.com/ledger-live",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://download.live.ledger.com/ledger-live-desktop-2.145.0-win-x64.exe#/dl.7z",
            "hash": "sha512:f29bc2cfe376377b05fc2b67c58e68a8707533b35f06062d3a5177a9d3aec8bec8bbe53541a768e02eff5d9a770ec8ffceb4b2e90abc82b04540a8fb08d88ba7",
            "installer": {
                "script": [
                    "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" -DestinationPath \"$dir\" -Removal",
                    "Remove-Item \"$dir\\`$R0\",\"$dir\\`$PLUGINSDIR\" -Force -Recurse"
                ]
            }
        }
    },
    "shortcuts": [
        [
            "Ledger Wallet.exe",
            "Ledger Wallet"
        ]
    ],
    "checkver": {
        "url": "https://download.live.ledger.com/latest.yml",
        "regex": "ledger-live-desktop-([\\d.]+)-win"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.live.ledger.com/ledger-live-desktop-$version-win-x64.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "https://download.live.ledger.com/latest.yml",
            "mode": "extract",
            "regex": "(?sm)$version-win-x64.exe.*?sha512: $base64"
        }
    }
}
