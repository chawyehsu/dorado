{
    "version": "3.2.3.1",
    "description": "Screenshots, screen recording, OCR tool.",
    "homepage": "https://pixpin.cn/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://pixpin.cn/docs/policy/tos_zh_CN"
    },
    "architecture": {
        "64bit": {
            "url": "https://download.pixpin.cn/PixPin_cn_zh-cn_3.2.3.1.zip#/dl.zip",
            "hash": "52f469aa83d8f6bf8615cb68b9afb95f22d7c766dc513471c8f14bf39801be31"
        }
    },
    "extract_dir": "PixPin",
    "shortcuts": [
        [
            "PixPin.exe",
            "PixPin"
        ]
    ],
    "persist": [
        "Config",
        "Data",
        "History",
        "OcrModel"
    ],
    "post_install": [
        "$configPath = \"$persist_dir\\Config\\PixPinConfig.json\"",
        "if (Test-Path $configPath) {",
        "    return",
        "}",
        "$timestamp = [DateTimeOffset]::Now.ToUnixTimeSeconds()",
        "$content = '{\"System.Update.UpgradeMode#s.win\":{\"t\":' + $timestamp + ',\"v\":0}}'",
        "$content | Set-Content -Path $configPath -Encoding UTF8"
    ],
    "checkver": {
        "url": "https://pixpin.cn/download/",
        "regex": "PixPin_cn_zh-cn_(\\d+(?:\\.\\d+)*)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.pixpin.cn/PixPin_cn_zh-cn_$version.zip#/dl.zip"
            }
        }
    }
}
