{
    "version": "1.27.2",
    "description": "A graphical tool for developing on containers and Kubernetes",
    "homepage": "https://podman-desktop.io/",
    "license": "Apache-2.0",
    "depends": "dorado/podman",
    "architecture": {
        "64bit": {
            "url": "https://github.com/podman-desktop/podman-desktop/releases/download/v1.27.2/podman-desktop-1.27.2-x64.exe#/podman-desktop.7z",
            "hash": "750902d9fbe15e6052c1cda0f4efadd34a13fb836154ad74fb74aff279451a78",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/podman-desktop/podman-desktop/releases/download/v1.27.2/podman-desktop-1.27.2-arm64.exe#/podman-desktop.7z",
            "hash": "0faaebbd047a761a081860d3a761f8a2dd33ba0ccf63786e0a6d35fe605f1de5",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse"
            ]
        }
    },
    "post_install": [
        "# https://github.com/podman-desktop/podman-desktop/blob/main/website/docs/configuration/settings-reference.md",
        "$settingsPath = Join-Path $env:USERPROFILE '\\.local\\share\\containers\\podman-desktop\\configuration\\settings.json'",
        "if (-not (Test-Path $settingsPath)) {",
        "    New-Item -ItemType Directory -Path (Split-Path $settingsPath) -Force | Out-Null",
        "    $defaultSettings = '{\"telemetry.enabled\":false,\"telemetry.check\":true,\"preferences.update.reminder\":\"never\"}'",
        "    $defaultSettings | Out-File -FilePath $settingsPath -Encoding UTF8",
        "}"
    ],
    "suggest": {
        "docker-compose": "dorado/docker-compose",
        "kubectl": "main/kubectl",
        "kind": "main/kind"
    },
    "shortcuts": [
        [
            "Podman Desktop.exe",
            "Podman Desktop"
        ]
    ],
    "checkver": {
        "github": "https://github.com/containers/podman-desktop"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/podman-desktop/podman-desktop/releases/download/v$version/podman-desktop-$version-x64.exe#/podman-desktop.7z"
            },
            "arm64": {
                "url": "https://github.com/podman-desktop/podman-desktop/releases/download/v$version/podman-desktop-$version-arm64.exe#/podman-desktop.7z"
            }
        }
    }
}
