{
    "version": "9.0-1",
    "description": "GNU nano text editor for Windows",
    "homepage": "https://github.com/chawyehsu/nano-for-windows",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/chawyehsu/nano-for-windows/releases/download/v9.0-1/nano-9.0-1-win-64.conda#/dl.zip",
            "hash": "12e70a1b0b2ad4ec61cae20b2af5db00dc76316240e8a290886314a9f5b484f1"
        },
        "arm64": {
            "url": "https://github.com/chawyehsu/nano-for-windows/releases/download/v9.0-1/nano-9.0-1-win-arm64.conda#/dl.zip",
            "hash": "b40ea361484ff0d264f331686e97ec7a2434c56e94199e39cbed2ef0aec44d88"
        }
    },
    "installer": {
        "script": [
            "Rename-Item $dir\\pkg*.tar.zst $dir\\nano.tar.zst",
            "Expand-7zipArchive $dir\\nano.tar.zst $dir",
            "Remove-Item $dir\\*.tar.zst,$dir\\metadata.json -Force -ErrorAction SilentlyContinue"
        ]
    },
    "bin": "bin\\nano.exe",
    "checkver": {
        "github": "https://api.github.com/repos/chawyehsu/nano-for-windows/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/chawyehsu/nano-for-windows/releases/download/v$version/nano-$version-win-64.conda#/dl.zip"
            },
            "arm64": {
                "url": "https://github.com/chawyehsu/nano-for-windows/releases/download/v$version/nano-$version-win-arm64.conda#/dl.zip"
            }
        }
    }
}
