{
    "homepage": "https://github.com/rust-lang-nursery/rustup.rs",
    "description": "The Rust toolchain installer",
    "version": "1.29.0",
    "license": "MIT|Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://static.rust-lang.org/rustup/archive/1.29.0/x86_64-pc-windows-msvc/rustup-init.exe",
            "hash": "86478e53f769379d7f0ebfa7c9aa97cb76ca92233f79aa2cc0dbee2efaac73c7"
        },
        "32bit": {
            "url": "https://static.rust-lang.org/rustup/archive/1.29.0/i686-pc-windows-msvc/rustup-init.exe",
            "hash": "f574ea2bd6d798b6072b3a45e3053f3cabcc2cb48d6b4bd59b661b41d675b31a"
        },
        "arm64": {
            "url": "https://static.rust-lang.org/rustup/archive/1.29.0/aarch64-pc-windows-msvc/rustup-init.exe",
            "hash": "3af309e6c3062aa11df0e932954f69d13b734d8a431e593812f3ecd9ff9e6ef6"
        }
    },
    "checkver": {
        "url": "https://raw.githubusercontent.com/rust-lang-nursery/rustup.rs/master/Cargo.toml",
        "regex": "version = \"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://static.rust-lang.org/rustup/archive/$version/x86_64-pc-windows-msvc/rustup-init.exe"
            },
            "32bit": {
                "url": "https://static.rust-lang.org/rustup/archive/$version/i686-pc-windows-msvc/rustup-init.exe"
            },
            "arm64": {
                "url": "https://static.rust-lang.org/rustup/archive/$version/aarch64-pc-windows-msvc/rustup-init.exe"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    },
    "installer": {
        "script": [
            "add_first_in_path \"$env:USERPROFILE\\.cargo\\bin\" $global",
            "# Install Rustup",
            "& \"$dir\\rustup-init.exe\" -y --no-modify-path --default-toolchain stable-msvc"
        ]
    },
    "uninstaller": {
        "script": "remove_from_path \"$env:USERPROFILE\\.cargo\\bin\" $global"
    },
    "notes": "To use the MSVC ABI without Visual Studio 2015 (or higher) installed, you will need the Visual Studio 2019 Build Tools: https://www.visualstudio.com/downloads/"
}
